{
    "wave_channels": 512,
    "sample_rate_hz": 20,
    "time_window": 32,
    "polish_heads": 1,
    "sg_filter": {
        "window_size": 11,
        "poly_order": 3
    },
    "endpoint_threshold": 0.85,
    "tensorrt": {
        "enabled": true,
        "gpu_device_id": 0,
        "engine_path": "models/epd_cnn_bilstm.engine"
    },
    "preprocessing": {
        "normalize": true,
        "pad_edges": true
    },
    "postprocessing": {
        "prob_smooth_window": 5,
        "streak_threshold": 3,
        "min_confidence": 0.5
    },
    "grad_cam": {
        "enable": true,
        "trigger_threshold": 0.90,
        "target_conv_layer": "conv_last",
        "heatmap_width": 200,
        "heatmap_height": 200,
        "wafer_diameter_mm": 300.0,
        "apply_colormap": true,
        "high_quality_upsample": true,
        "conv_channels": 64,
        "conv_spatial_size": 512
    }
}
